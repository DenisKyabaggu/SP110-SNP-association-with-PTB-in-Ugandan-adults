print("\n── Power Analysis ──")

def allele_power(nc, nk, pc, pk, alpha=0.05):
    na1=2*nc; na0=2*nk
    pb=(na1*pc+na0*pk)/(na1+na0)
    if pb in (0,1): return 0.
    se0=np.sqrt(pb*(1-pb)*(1/na1+1/na0))
    se1=np.sqrt(pc*(1-pc)/na1+pk*(1-pk)/na0)
    if se0==0 or se1==0: return 0.
    za=stats.norm.ppf(1-alpha/2)
    return float(stats.norm.cdf((abs(pc-pk)-za*se0)/se1))

pwr_rows=[]
