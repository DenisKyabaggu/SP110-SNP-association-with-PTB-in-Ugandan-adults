    nt = len(av)
    af_all = av.sum()/(2*nt);  af_p = pv.sum()/(2*len(pv)); af_n = nv.sum()/(2*len(nv))
    # Missingness Fisher test
    mp = pos[col].isna().sum(); mn_ = neg[col].isna().sum()
    if mp+mn_ > 0:
        _, p_miss = stats.fisher_exact([[len(pv),mp],[len(nv),mn_]])
    else:
        p_miss = 1.0
    # HWE chi-sq in controls only
    nc=len(nv); n0=(nv==0).sum(); n1=(nv==1).sum(); n2=(nv==2).sum()
    p_alt=((2*n2+n1)/(2*nc)); q=1-p_alt
    e0,e1,e2 = nc*q**2, nc*2*p_alt*q, nc*p_alt**2
    if all(e>0 for e in [e0,e1,e2]):
        x2 = (n0-e0)**2/e0+(n1-e1)**2/e1+(n2-e2)**2/e2
        p_hwe = 1-chi2.cdf(x2, 1)
    else:
        p_hwe = np.nan
    t2.append({"SNP":m["SNP"], "Chr":"2", "Position (hg19)":m["Pos_hg19"],
               "Ref":m["Ref"], "Alt":m["Alt"],
