def logistic(data, snp_col, extra=[]):
    adf = data[["PTB", snp_col, "AGE", "is_male"] + extra].dropna()
    if len(adf)<10 or adf[snp_col].nunique()<2: return None
    X = sm.add_constant(adf[[snp_col,"AGE","is_male"]+extra])
    try:
        r = sm.Logit(adf["PTB"], X).fit(disp=0, maxiter=200)
        if snp_col not in r.params: return None
        b=r.params[snp_col]; ci=r.conf_int().loc[snp_col]; p=r.pvalues[snp_col]
        return {"OR":round(np.exp(b),3),
                "95% CI lower":round(np.exp(ci[0]),3),
                "95% CI upper":round(np.exp(ci[1]),3),
                "p-value":round(p,4), "N":len(adf)}
    except: return None

def bh_fdr(pvals):
    n=len(pvals); order=np.argsort(pvals); fdr=np.empty(n)
    fdr[order]=pvals[order]*n/(np.arange(n)+1)
    for i in range(n-2,-1,-1):
        fdr[order[i]]=min(fdr[order[i]], fdr[order[i+1]])
    return np.round(np.minimum(fdr,1.0), 4)

def run_assoc(data, label, extra=[]):
    results=[]
    for _,m in SNP_META.iterrows():
        snp=m["SNP"]; base=data[snp+"_alt"]
        models={"Additive":base,
                "Dominant":(base>=1).astype(float),
                "Recessive":(base==2).astype(float),
                "Overdominant":(base==1).astype(float)}
        for mname,gcoded in models.items():
            tmp=data.copy(); tmp["_g"]=gcoded
            r=logistic(tmp,"_g",extra)
            if r:
                # Flag non-convergence / extreme ORs
                if r["OR"]>100 or r["OR"]<0.001:
                    r["OR"]=np.nan; r["95% CI lower"]=np.nan
                    r["95% CI upper"]=np.nan; r["p-value"]=np.nan
                r.update({"SNP":snp,"Model":mname,"Analysis":label})
                results.append(r)
    if not results: return pd.DataFrame()
    out=pd.DataFrame(results)
    valid=out["p-value"].notna()
    out.loc[valid,"FDR"]=bh_fdr(out.loc[valid,"p-value"].values)
    return out[["SNP","Model","Analysis","OR","95% CI lower","95% CI upper",
                "p-value","FDR","N"]].sort_values("p-value")

