def load_duplicates(path):
    """Load duplicate records to remove without hard-coding participant IDs."""
    if not path or not os.path.exists(path):
        return []

    duplicates = pd.read_csv(path, dtype=str).fillna("")
    required = {"removed_id"}
    missing = required.difference(duplicates.columns)
    if missing:
        raise ValueError(
            f"Duplicate-removal file is missing required columns: {sorted(missing)}"
        )

    records = []
    for _, row in duplicates.iterrows():
        removed_id = str(row["removed_id"]).strip()
        if not removed_id:
            continue
        records.append({
            "removed_id": removed_id,
            "kept_id": str(row.get("kept_id", "")).strip(),
            "note": str(row.get("note", "")).strip(),
        })
    return records


