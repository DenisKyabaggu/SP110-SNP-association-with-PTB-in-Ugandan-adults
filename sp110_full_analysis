# Excel style helpers
def style_title(cell, text):
    cell.value = text
    cell.font = Font(name="Arial", bold=True, size=13, color="FFFFFF")
    cell.fill = PatternFill("solid", fgColor="1F4E79")
    cell.alignment = Alignment(horizontal="left", vertical="center",
                                wrap_text=True)

def style_header(cell):
    cell.font  = Font(name="Arial", bold=True, size=10, color="FFFFFF")
    cell.fill  = PatternFill("solid", fgColor="2E75B6")
    cell.alignment = Alignment(horizontal="center", vertical="center",
                                wrap_text=True)
    thin = Side(style="thin", color="FFFFFF")
    cell.border = Border(left=thin, right=thin, bottom=thin, top=thin)

def style_subheader(cell):
    cell.font  = Font(name="Arial", bold=True, size=10, color="1F4E79")
    cell.fill  = PatternFill("solid", fgColor="D6E4F0")
    cell.alignment = Alignment(horizontal="left", vertical="center")

def style_data(cell, even=True, bold=False, indent=False, highlight=False):
    cell.font = Font(name="Arial", bold=bold, size=10,
                     color="C00000" if highlight else "000000")
    cell.fill = PatternFill("solid", fgColor="EBF3FB" if even else "FFFFFF")
    xalign = "right" if isinstance(cell.value, (int,float)) else "left"
    cell.alignment = Alignment(horizontal=xalign, vertical="center",
                                indent=2 if indent else 0)
    thin = Side(style="thin", color="D9D9D9")
    cell.border = Border(left=thin, right=thin, top=thin, bottom=thin)


def set_col_widths(ws, widths):
    for col, w in widths.items():
        ws.column_dimensions[col].width = w

def freeze(ws, cell="A3"):
    ws.freeze_panes = ws[cell]

def add_title_row(ws, title, ncols):
    ws.append([title])
    ws.merge_cells(start_row=ws.max_row, start_column=1,
                   end_row=ws.max_row, end_column=ncols)
    style_title(ws.cell(ws.max_row, 1), title)
    ws.row_dimensions[ws.max_row].height = 24


